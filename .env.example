DATABASE_URL=postgresql://logs_user:logs_password@postgres:5432/logs_db
REDIS_URL=redis://redis:6379/0
DEBUG=True
API_PORT=8000

# AWS credentials — required for S3 warm tier archival
# Create an IAM user with S3 permissions and paste the keys here
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-2
S3_BUCKET=your-bucket-name-here

ARCHIVE_INTERVAL_SECONDS=300

# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change_this_to_a_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
AUTH_REQUIRED=true
